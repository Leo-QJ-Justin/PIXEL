# Telegram API credentials
# Get these from https://my.telegram.org/apps
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Monitored Telegram user IDs (comma-separated)
# These users will trigger Haro alerts when they send messages
# Find user IDs by forwarding a message from them to @userinfobot
MONITORED_USERS=123456789,987654321

# OpenWeatherMap API key
# Get one for free at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# Google Calendar OAuth credentials
# Create at https://console.cloud.google.com/apis/credentials
# Enable the Google Calendar API first
GOOGLE_CALENDAR_CLIENT_ID=your_client_id_here
GOOGLE_CALENDAR_CLIENT_SECRET=your_client_secret_here
