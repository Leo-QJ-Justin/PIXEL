# Telegram API credentials
# Get these from https://my.telegram.org/apps
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Monitored Telegram user IDs (comma-separated)
# These users will trigger Haro alerts when they send messages
# Find user IDs by forwarding a message from them to @userinfobot
MONITORED_USERS=123456789,987654321

# OpenWeatherMap API key
# Get one for free at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# Google Calendar OAuth credentials
# Create at https://console.cloud.google.com/apis/credentials
# Enable the Google Calendar API first
GOOGLE_CALENDAR_CLIENT_ID=your_client_id_here
GOOGLE_CALENDAR_CLIENT_SECRET=your_client_secret_here

# Google Maps API key (for Routes + Geocoding APIs)
# Get one at https://console.cloud.google.com/apis/credentials
# Enable: Routes API + Geocoding API (10,000 free calls/month each)
# Optional — if not set, falls back to OneMap or flat 30-min alert
GOOGLE_MAPS_API_KEY=your_api_key_here

# OneMap Singapore credentials (free routing fallback)
# Register at https://www.onemap.gov.sg/apidocs/register
# Optional — used when Google Maps key is not set or quota exhausted
ONEMAP_EMAIL=your_email_here
ONEMAP_PASSWORD=your_password_here

# Sprite Generation (only needed for scripts/sprite_pipeline.py)
# Create a project at https://console.cloud.google.com
# Enable the Vertex AI API
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# LLM Personality Engine (optional)
# Override the API key / endpoint set in Settings UI
# LLM_API_KEY=your_api_key_here
# LLM_ENDPOINT=http://localhost:11434
